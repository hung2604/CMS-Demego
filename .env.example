# Chuỗi kết nối (auth DB thường là admin; ứng dụng dùng MONGODB_DB bên dưới)
MONGODB_URI=mongodb://USER:PASSWORD@HOST:PORT/admin?authSource=admin

# Tên database nghiệp vụ
MONGODB_DB=cms

# Vercel Blob (upload ảnh logo/favicon/nội dung bài viết từ admin) — Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=

# (Tùy chọn) Bảo vệ POST /api/seed trên production — body JSON: { "token": "<giá trị>", "wipe": true }
# Trên môi trường dev, seed luôn được phép (không cần token).
SEED_TOKEN=

# Session cookie (nuxt-auth-utils) — production: đặt chuỗi ngẫu nhiên ≥ 32 ký tự
NUXT_SESSION_PASSWORD=

# Cho phép đăng ký qua form trên /admin/login?register=1 (chỉ bật khi cần; production thường để false hoặc bỏ trống)
ADMIN_ALLOW_REGISTER=
