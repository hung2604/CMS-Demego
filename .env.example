# --- Nuxt Studio (bắt buộc nếu mở /_studio hoặc publish trên production) ---
# Tạo OAuth App: https://github.com/settings/developers → New OAuth App
# Authorization callback URL (dev):  http://localhost:3000/__nuxt_studio/auth/github
# Authorization callback URL (prod): https://YOUR-DOMAIN.com/__nuxt_studio/auth/github
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=

# Tuỳ chọn: chỉ email sau dấu phẩy được vào Studio (GitHub OAuth)
# STUDIO_GITHUB_MODERATORS=you@example.com

# Tuỳ chọn: repo (nếu không deploy Vercel / không bật system env)
# STUDIO_REPO_OWNER=
# STUDIO_REPO_NAME=
# STUDIO_REPO_BRANCH=main

# Giới hạn upload media (bytes). Mặc định trong nuxt.config là 500MB nếu không set.
# STUDIO_MEDIA_MAX_BYTES=524288000
